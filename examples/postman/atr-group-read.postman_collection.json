      "name": "Group",
      "item": [
        {
          "name": "GET Group by id (full)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/fhir+json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/Group/{{groupId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "Group",
                "{{groupId}}"
              ]
            },
            "description": "Returns full ATR Group payload including member list."
          },
          "response": []
        },
        {
          "name": "GET Group by id (summary)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/fhir+json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }

            "url": {
              "raw": "{{baseUrl}}/Group/{{groupId}}?_summary=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "Group",
                "{{groupId}}"
              ],
              "query": [
                {
                  "key": "_summary",
                  "value": "true"
                }
              ]
            },
            "description": "Returns Group summary and omits member list."
          },
          "response": []
        },
        {
